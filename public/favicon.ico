  <!-- Lines -->
  <rect x="10" y="14" width="10" height="1" fill="#E5E7EB"/>
  <rect x="10" y="17" width="12" height="1" fill="#E5E7EB"/>
  
  <!-- Small table -->
  <rect x="10" y="21" width="12" height="5" fill="#F3F4F6"/>
</svg>
