<?xml version="1.0" encoding="UTF-8"?>
<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" rx="128" fill="#8B1A1A"/>
  
  <!-- Invoice Icon -->
  <rect x="128" y="96" width="256" height="352" rx="16" fill="white"/>
  
  <!-- Header -->
  <rect x="160" y="128" width="192" height="24" rx="6" fill="#8B1A1A"/>
  <text x="256" y="148" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="white" text-anchor="middle">BillMint</text>
  
  <!-- Lines -->
  <rect x="160" y="180" width="160" height="12" rx="4" fill="#E5E7EB"/>
  <rect x="160" y="208" width="192" height="12" rx="4" fill="#E5E7EB"/>
  <rect x="160" y="236" width="140" height="12" rx="4" fill="#E5E7EB"/>
  
  <!-- Table -->
  <rect x="160" y="280" width="192" height="120" rx="8" fill="#F3F4F6"/>
  <line x1="160" y1="312" x2="352" y2="312" stroke="#8B1A1A" stroke-width="4"/>
  <line x1="256" y1="280" x2="256" y2="400" stroke="#8B1A1A" stroke-width="4"/>
  
  <!-- Rupee Symbol -->
  <text x="256" y="380" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="#8B1A1A" text-anchor="middle">₹</text>
</svg>
